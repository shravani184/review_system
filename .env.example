# ===== Service =====
LOG_LEVEL=INFO
WORKSPACE_ROOT=/tmp/review_workspaces

# ===== LLM provider =====
# Leave OPENAI_API_KEY empty to run in deterministic OFFLINE explainer mode.
# The neuro-symbolic contract (no hallucinated issues) holds in both modes.
LLM_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=1500

# ===== Limits =====
MAX_FILES_PER_REQUEST=20
MAX_FILE_BYTES=1000000

# ===== Custom rule thresholds (prefix RULE_) =====
RULE_MAX_FUNCTION_LENGTH=50
RULE_MAX_PARAMETERS=5
RULE_MAX_NESTING_DEPTH=4
RULE_MAX_CYCLOMATIC_COMPLEXITY=10
RULE_MAX_LINE_LENGTH=100
RULE_ENFORCE_TYPE_HINTS=true
RULE_ENFORCE_DOCSTRINGS=true
RULE_FLAG_MAGIC_NUMBERS=true
RULE_FLAG_NESTED_LOOPS=true

# ===== Confidence weights (prefix CONF_, should sum to 1.0) =====
CONF_STATIC_TOOL_WEIGHT=0.5
CONF_LLM_AGREEMENT_WEIGHT=0.3
CONF_RULE_RELIABILITY_WEIGHT=0.2
